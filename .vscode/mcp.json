{
  "servers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "tanstack": {
      "command": "npx",
      "args": ["@tanstack/cli", "mcp"]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=yxiirmcplqkwjwknsfue"
    },
    "playwright-test": {
      "type": "stdio",
      "command": "npx",
      "args": ["playwright", "run-test-mcp-server"],
