# Database Connection (Required for Drizzle ORM)
# For local Supabase: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# For Vercel Postgres: postgres://default:password@ep-....us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application URLs
# 🚀 VERCEL AUTO-DETECTION (recommended):
# - Leave these unset in Vercel Dashboard
# - The app will auto-detect based on VERCEL_ENV, VERCEL_URL
#
# ⚙️ MANUAL OVERRIDE (if needed):
# - Set FRONTEND_URL for custom domain in production
# - Set API_URL if using separate API server
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:3000

# Environment
# ⚠️ WARNING: Vercel overwrites NODE_ENV in production
# Use VERCEL_ENV instead (auto-set by Vercel):
#   - development (local dev)
#   - preview (PR deployments)
#   - production (main branch)
NODE_ENV=development

# ============================================
# Email Service (Gmail SMTP)
# ============================================
# Development: Emails are MOCKED (verification link logged to console)
# Production: Real emails sent via Gmail SMTP
#
# Setup for production:
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy 16-char password (no spaces): abcdefghijklmnop
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password  # 16 characters, no spaces
